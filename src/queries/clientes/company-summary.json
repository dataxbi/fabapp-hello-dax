{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "mark": { "type": "bar", "cornerRadiusEnd": 8 },
  "encoding": {
    "y": { "field": "EmpresaCompany", "type": "nominal", "sort": "-x", "axis": { "title": null } },
    "x": { "field": "Revenue", "type": "quantitative", "axis": { "title": "Facturacion" } },
    "tooltip": [
      { "field": "EmpresaCompany", "type": "nominal", "title": "Empresa" },
      { "field": "Revenue", "type": "quantitative", "title": "Facturacion" },
      { "field": "Margin", "type": "quantitative", "title": "Margen" },
      { "field": "MarginPercent", "type": "quantitative", "title": "Margen %" }
    ]
  }
}
